# Copy to .env.local and fill in. Add the same vars in Vercel → Settings → Environment Variables.

# Supabase — supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, keep secret

# Admin dashboard login (/admin)
ADMIN_PASSWORD=choose-a-strong-password
SESSION_SECRET=any-long-random-string-32+chars
